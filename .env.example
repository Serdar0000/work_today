# Copy this file to .env and fill real values

FIREBASE_ANDROID_API_KEY=
FIREBASE_ANDROID_APP_ID=
FIREBASE_ANDROID_MESSAGING_SENDER_ID=
FIREBASE_ANDROID_PROJECT_ID=
FIREBASE_ANDROID_STORAGE_BUCKET=

FIREBASE_IOS_API_KEY=
FIREBASE_IOS_APP_ID=
FIREBASE_IOS_MESSAGING_SENDER_ID=
FIREBASE_IOS_PROJECT_ID=
FIREBASE_IOS_STORAGE_BUCKET=
FIREBASE_IOS_BUNDLE_ID=

# Только debug: при true не вызывается Firebase/локальный вход на splash — сразу «вошедший» пользователь
DEBUG_AUTH_BYPASS=false
# worker | company
DEBUG_AUTH_ROLE=worker
DEBUG_AUTH_EMAIL=debug@local.dev
DEBUG_AUTH_NAME=Debug User
