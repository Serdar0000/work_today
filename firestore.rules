rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read, write: if isOwner(uid);
    }

    match /profiles/{uid} {
      allow read, write: if isOwner(uid);
    }

    match /jobSeekerProfiles/{uid} {
      allow read, write: if isOwner(uid);
    }

    match /companyProfiles/{uid} {
      allow read, write: if isOwner(uid);
    }

    match /resumes/{uid} {
      // соискатель редактирует своё резюме
      allow write: if isOwner(uid);
      // компания может читать публичные резюме
      allow read: if signedIn() && resource.data.isPublic == true;
      allow read: if isOwner(uid);
    }

    match /vacancies/{vacancyId} {
      // на MVP: любой залогиненный читает вакансии
      allow read: if signedIn();
      // создавать/менять может только авторизованный (владельца лучше фиксировать полем ownerUid в данных)
      allow create, update, delete: if signedIn();
    }
  }
}
